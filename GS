  if (sheet.getLastRow() === 0) sheet.appendRow(['時間戳記', '組別', '上傳者', '原始檔名', '圖片網址']);
  sheet.appendRow([new Date(), p.group, p.name, p.fileName, p.url]);
  return { success: true };
}

// 取得特定學員的各項作業繳交紀錄
function getUserHomeworkHistory(group, name) {
  const ss = SpreadsheetApp.openById(SPREADSHEET_ID);
  const sheets = ss.getSheets();
  const history = [];
  for (let i = 0; i < sheets.length; i++) {
    const sheet = sheets[i];
    const sheetName = sheet.getName();
    if (sheetName.indexOf('作業_') === 0) {
      const topic = sheetName.replace('作業_', '');
      const data = sheet.getDataRange().getValues();
      if (data.length > 1) {
        for (let j = 1; j < data.length; j++) {
          const row = data[j];
          if (row[1] == group && row[2] == name) {
             let timeStr = row[0];
             if (timeStr instanceof Date) {
               timeStr = Utilities.formatDate(timeStr, "GMT+8", "yyyy/MM/dd HH:mm");
             } else { timeStr = timeStr.toString(); }
             history.push({ topic: topic, time: timeStr, reflection: row[4] ? row[4].toString() : "", url: row[5] ? row[5].toString() : "" });
          }
        }
      }
    }
  }
  history.sort(function(a, b) { return new Date(b.time) - new Date(a.time); });
  return { success: true, data: history };
}